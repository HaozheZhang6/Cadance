\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Capability profile and qualitative failure modes} (frontier proprietary subset). \emph  {Left:} per-model capability radar across six axes (surface similarity, local feature accuracy, global geometry, CAD understanding, CAD code robustness, synthesis). \emph  {Right:} four representative failure modes elicited by BenchCAD's hard tier on the strongest reasoning models: \emph  {(i) no industry understanding} --- a coil spring rendered as stacked disks because the model never produced a helical sweep; \emph  {(ii) wrong plane} --- correct features on the wrong base workplane; \emph  {(iii) wrong ops} --- a bracket needing chamfer + Boolean cut rendered as a single extrude; \emph  {(iv) no detail} --- a bolt omitting thread, fillet, and head detail expected by DIN/ISO standards.}}{18}{figure.7}\protected@file@percent }
\newlabel{fig:capability_profile}{{7}{18}{\textbf {Capability profile and qualitative failure modes} (frontier proprietary subset). \emph {Left:} per-model capability radar across six axes (surface similarity, local feature accuracy, global geometry, CAD understanding, CAD code robustness, synthesis). \emph {Right:} four representative failure modes elicited by BenchCAD's hard tier on the strongest reasoning models: \emph {(i) no industry understanding} --- a coil spring rendered as stacked disks because the model never produced a helical sweep; \emph {(ii) wrong plane} --- correct features on the wrong base workplane; \emph {(iii) wrong ops} --- a bracket needing chamfer + Boolean cut rendered as a single extrude; \emph {(iv) no detail} --- a bolt omitting thread, fillet, and head detail expected by DIN/ISO standards}{figure.7}{}}
