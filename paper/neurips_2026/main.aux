\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {BenchCAD dataset composition.} The verified evaluation core consists of 17{,}900 procedurally generated parts spanning 106 families, with each record carrying parametric source code, executable STEP, four canonical-view renders, and a parameter JSON. The QA bank contains 2{,}400 paired questions evaluated under both visual and code conditioning. We additionally release an Edit subset, a stratified Lite split, two OOD subsets, and a 162K-pair training corpus.}}{14}{table.5}\protected@file@percent }
\newlabel{tab:dataset}{{5}{14}{\textbf {BenchCAD dataset composition.} The verified evaluation core consists of 17{,}900 procedurally generated parts spanning 106 families, with each record carrying parametric source code, executable STEP, four canonical-view renders, and a parameter JSON. The QA bank contains 2{,}400 paired questions evaluated under both visual and code conditioning. We additionally release an Edit subset, a stratified Lite split, two OOD subsets, and a 162K-pair training corpus}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Capability decomposition.} BenchCAD's five tasks exercise known subsets of the four-level capability hierarchy: $L_1$ Holistic Visual Recognition (recognise + integrate multi-view), $L_2$ CAD Operations Understanding (read code, map ops to features), $L_3$ Industrial Parametric Abstraction (parameter structure, standard conventions), and $L_4$ Spatial/Code Reasoning (compose all into executable program). Score differences across paired tasks (e.g.\ \texttt  {qa\_img}$-$\texttt  {qa\_code}) directly diagnose which level is the bottleneck. ``part.'' indicates partial coverage.}}{14}{table.6}\protected@file@percent }
\newlabel{tab:capability}{{6}{14}{\textbf {Capability decomposition.} BenchCAD's five tasks exercise known subsets of the four-level capability hierarchy: $L_1$ Holistic Visual Recognition (recognise + integrate multi-view), $L_2$ CAD Operations Understanding (read code, map ops to features), $L_3$ Industrial Parametric Abstraction (parameter structure, standard conventions), and $L_4$ Spatial/Code Reasoning (compose all into executable program). Score differences across paired tasks (e.g.\ \texttt {qa\_img}$-$\texttt {qa\_code}) directly diagnose which level is the bottleneck. ``part.'' indicates partial coverage}{table.6}{}}
