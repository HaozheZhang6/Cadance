\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Edit task analysis.} \emph  {Top:} Pass@1 (\%) per edit category on BenchCAD-Edit (748 pairs). Multi-step edits requiring parameter-dependency reasoning collapse below 15\% across every model. \emph  {Bottom:} Disaggregating Pass@1 reveals \textbf  {Industrial Common Sense Gap}: target-feature success is high, but program-wide preservation fails in the majority of nominally successful edits. \emph  {Diff bloat} = (lines model changed) / (minimal correct diff); even on dimensional edits where minimal diff is one line, top models average 7--10 changed lines. \textcolor {red}{Placeholders.}}}{9}{table.2}\protected@file@percent }
\newlabel{tab:edit_leakage}{{2}{9}{\textbf {Edit task analysis.} \emph {Top:} Pass@1 (\%) per edit category on BenchCAD-Edit (748 pairs). Multi-step edits requiring parameter-dependency reasoning collapse below 15\% across every model. \emph {Bottom:} Disaggregating Pass@1 reveals \textbf {Industrial Common Sense Gap}: target-feature success is high, but program-wide preservation fails in the majority of nominally successful edits. \emph {Diff bloat} = (lines model changed) / (minimal correct diff); even on dimensional edits where minimal diff is one line, top models average 7--10 changed lines. \textcolor {red}{Placeholders.}}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {The edit task: scoring pipeline, examples, and per-model leaderboard.} \emph  {Top:} scoring pipeline (input CAD program + NL instruction $\to $ code LLM $\to $ predicted code; render both predicted and GT, score by IoU). \emph  {Middle:} four original/edited geometry pairs and a concrete instance with the CadQuery program including the parametric coupling \texttt  {chamfer\_drop = chamfer\_length * math.tan(math.radians(chamfer\_angle))}. \emph  {Bottom:} per-model leaderboard across five metrics, showing strict $\geq 0.99$ pass rate trails mean IoU substantially despite high execution rates.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:edit_task}{{5}{9}{\textbf {The edit task: scoring pipeline, examples, and per-model leaderboard.} \emph {Top:} scoring pipeline (input CAD program + NL instruction $\to $ code LLM $\to $ predicted code; render both predicted and GT, score by IoU). \emph {Middle:} four original/edited geometry pairs and a concrete instance with the CadQuery program including the parametric coupling \texttt {chamfer\_drop = chamfer\_length * math.tan(math.radians(chamfer\_angle))}. \emph {Bottom:} per-model leaderboard across five metrics, showing strict $\geq 0.99$ pass rate trails mean IoU substantially despite high execution rates}{figure.5}{}}
