\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {BenchCAD-QA capability hierarchy and representative items.} \emph  {Left:} the 4-level capability ladder underlying the BenchCAD-QA bank, arranged from low-level visual recognition at the base to high-level synthesis at the apex --- \emph  {(L1) Feature Recognition} (does the part belong to a known family?), \emph  {(L2) Code \& Operation} (which CadQuery operation produces a given feature?), \emph  {(L3) Inference \& Transformation} (numerical reasoning over parameters and operations), and \emph  {(L4) Synthesis \& Creativity} (geometric changes and reconstruction of unseen entities). \emph  {Right:} representative \texttt  {qa\_img} (visual) and \texttt  {qa\_code} (code-conditioned) items at each level. The hierarchy is complementary to the three-rung pyramid of \S  \ref {sec:capability}: the pyramid decomposes the image$\to $code \emph  {pipeline} into stages, while this hierarchy stratifies QA \emph  {difficulty} for the same set of parts.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:capability_hierarchy}{{3}{10}{\textbf {BenchCAD-QA capability hierarchy and representative items.} \emph {Left:} the 4-level capability ladder underlying the BenchCAD-QA bank, arranged from low-level visual recognition at the base to high-level synthesis at the apex --- \emph {(L1) Feature Recognition} (does the part belong to a known family?), \emph {(L2) Code \& Operation} (which CadQuery operation produces a given feature?), \emph {(L3) Inference \& Transformation} (numerical reasoning over parameters and operations), and \emph {(L4) Synthesis \& Creativity} (geometric changes and reconstruction of unseen entities). \emph {Right:} representative \texttt {qa\_img} (visual) and \texttt {qa\_code} (code-conditioned) items at each level. The hierarchy is complementary to the three-rung pyramid of \S \ref {sec:capability}: the pyramid decomposes the image$\to $code \emph {pipeline} into stages, while this hierarchy stratifies QA \emph {difficulty} for the same set of parts}{figure.3}{}}
