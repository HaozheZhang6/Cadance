\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {BenchCAD as an evaluation framework.} BenchCAD complements existing CAD-LM training corpora by providing the evaluation-side properties they do not: an industrial-family taxonomy with explicit functional identity, parameter anchoring against ISO/DIN/EN/ASME/IEC standard tables, verified before/after edit pairs with a non-target preservation metric, a paired numeric-QA bank, and a capability-decomposed scoring protocol. The rightmost column shows the strongest open CadQuery training corpus (CADEvolve, 2.7M scripts, DeepCAD image IoU 92.6) for reference; full per-axis comparison against all prior CAD code-generation work appears in Appendix~\ref {app:cmp_prior}.}}{5}{table.1}\protected@file@percent }
\newlabel{tab:advantages}{{1}{5}{\textbf {BenchCAD as an evaluation framework.} BenchCAD complements existing CAD-LM training corpora by providing the evaluation-side properties they do not: an industrial-family taxonomy with explicit functional identity, parameter anchoring against ISO/DIN/EN/ASME/IEC standard tables, verified before/after edit pairs with a non-target preservation metric, a paired numeric-QA bank, and a capability-decomposed scoring protocol. The rightmost column shows the strongest open CadQuery training corpus (CADEvolve, 2.7M scripts, DeepCAD image IoU 92.6) for reference; full per-axis comparison against all prior CAD code-generation work appears in Appendix~\ref {app:cmp_prior}}{table.1}{}}
