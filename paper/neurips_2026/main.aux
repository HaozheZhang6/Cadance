\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}The Family Cliff}{13}{subsection.5.4}\protected@file@percent }
\newlabel{sec:exp_cliff}{{5.4}{13}{The Family Cliff}{subsection.5.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Capability profile and qualitative failure modes} (frontier proprietary subset). \emph  {Left:} per-model capability radar across six axes --- surface similarity, local feature accuracy, global geometry, CAD understanding, CAD code robustness, and a sixth synthesis axis --- showing that no model dominates on all dimensions and that strengthen-on-one often coincides with weaken-on-another. \emph  {Right:} four representative failure modes elicited by BenchCAD's hard tier on the strongest reasoning models, illustrating concrete capability deficits that the aggregate scores in Table~\ref {tab:main_eval} compress: \emph  {(i) no industry understanding} --- a coil spring that lacks the helical sweep entirely; \emph  {(ii) wrong plane} --- a part with the correct features placed on the wrong base workplane; \emph  {(iii) wrong ops} --- a bracket whose target was a chamfer + boolean cut but the model emitted only a single extrude; \emph  {(iv) no detail} --- a bolt that omits thread, fillet, and head detail expected by the standard.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:capability_profile}{{5}{14}{\textbf {Capability profile and qualitative failure modes} (frontier proprietary subset). \emph {Left:} per-model capability radar across six axes --- surface similarity, local feature accuracy, global geometry, CAD understanding, CAD code robustness, and a sixth synthesis axis --- showing that no model dominates on all dimensions and that strengthen-on-one often coincides with weaken-on-another. \emph {Right:} four representative failure modes elicited by BenchCAD's hard tier on the strongest reasoning models, illustrating concrete capability deficits that the aggregate scores in Table~\ref {tab:main_eval} compress: \emph {(i) no industry understanding} --- a coil spring that lacks the helical sweep entirely; \emph {(ii) wrong plane} --- a part with the correct features placed on the wrong base workplane; \emph {(iii) wrong ops} --- a bracket whose target was a chamfer + boolean cut but the model emitted only a single extrude; \emph {(iv) no detail} --- a bolt that omits thread, fillet, and head detail expected by the standard}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {The Family Cliff.} \texttt  {img2cq} pass rate (\%) split by family difficulty tier. Even the strongest reasoning model collapses on the hard tier, exhibiting a $>$45-point gap from easy. The 26 hard-tier families exercise advanced operations (helical sweeps, twist-extrusion, lofted Booleans) and parametric constraints (gear module--tooth--pitch consistency, spring free-length--turn-count coupling) that no evaluated model reliably preserves. \textcolor {red}{Numbers are placeholders.}}}{14}{table.6}\protected@file@percent }
\newlabel{tab:family_cliff}{{6}{14}{\textbf {The Family Cliff.} \texttt {img2cq} pass rate (\%) split by family difficulty tier. Even the strongest reasoning model collapses on the hard tier, exhibiting a $>$45-point gap from easy. The 26 hard-tier families exercise advanced operations (helical sweeps, twist-extrusion, lofted Booleans) and parametric constraints (gear module--tooth--pitch consistency, spring free-length--turn-count coupling) that no evaluated model reliably preserves. \textcolor {red}{Numbers are placeholders.}}{table.6}{}}
