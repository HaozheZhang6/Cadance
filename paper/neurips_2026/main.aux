\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Main evaluation on BenchCAD-QA (\texttt  {qa\_img} modality), by capability axis.} Per-model accuracy on the visual-conditioned QA bank across the four BenchCAD-QA capability axes: \emph  {Holistic Visual Recognition}, \emph  {CAD Operation Understanding}, \emph  {Industrial Parametric Abstraction}, and \emph  {Spatial / Code Reasoning} (\S  \ref {sec:capability}). \textbf  {Total score} is the weighted mean across axes. Rows with empty entries indicate models not yet evaluated. The matched code-conditioned modality is reported in Table~\ref {tab:main_eval_code}.}}{15}{table.7}\protected@file@percent }
\newlabel{tab:main_eval}{{7}{15}{\textbf {Main evaluation on BenchCAD-QA (\texttt {qa\_img} modality), by capability axis.} Per-model accuracy on the visual-conditioned QA bank across the four BenchCAD-QA capability axes: \emph {Holistic Visual Recognition}, \emph {CAD Operation Understanding}, \emph {Industrial Parametric Abstraction}, and \emph {Spatial / Code Reasoning} (\S \ref {sec:capability}). \textbf {Total score} is the weighted mean across axes. Rows with empty entries indicate models not yet evaluated. The matched code-conditioned modality is reported in Table~\ref {tab:main_eval_code}}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces \textbf  {Main evaluation on BenchCAD-QA (\texttt  {qa\_code} modality), by capability axis.} Per-model accuracy on the code-conditioned QA bank across the same four capability axes as Table~\ref {tab:main_eval}. The two tables share questions and capability-axis definitions; only the conditioning modality differs (rendered images vs.\ source CadQuery). Score differences across the matched pair isolate the cost of replacing direct code access with visual recognition --- the \textbf  {Holistic Spatial and Detailing Deficit} (\S  \ref {sec:exp_capability}).}}{15}{table.8}\protected@file@percent }
\newlabel{tab:main_eval_code}{{8}{15}{\textbf {Main evaluation on BenchCAD-QA (\texttt {qa\_code} modality), by capability axis.} Per-model accuracy on the code-conditioned QA bank across the same four capability axes as Table~\ref {tab:main_eval}. The two tables share questions and capability-axis definitions; only the conditioning modality differs (rendered images vs.\ source CadQuery). Score differences across the matched pair isolate the cost of replacing direct code access with visual recognition --- the \textbf {Holistic Spatial and Detailing Deficit} (\S \ref {sec:exp_capability})}{table.8}{}}
