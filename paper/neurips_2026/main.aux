\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {BenchCAD versus prior CAD code-generation work.} BenchCAD is designed as a \emph  {unified, capability-decomposed evaluation framework} for large-model CAD reasoning, intended to remain useful as the field evolves from current frontier MLLMs (GPT-5.3, Claude Opus 4.7, $\ldots  $) toward future CAD agents and generative systems. It is distinct in purpose from the prior CadQuery-VLM lineage (CAD-Recode, cadrille, CADEvolve), which primarily releases training corpora alongside small fine-tuned models (Qwen 1.5B--2B) that saturate near $\sim $92\% IoU on legacy sketch+extrude test splits. \textbf  {Columns:} \textbf  {Type}: \emph  {corpus+model} = training corpus released with a fine-tuned model, \emph  {benchmark} = held-out evaluation suite, \emph  {dataset} = mixed-purpose CAD design dataset; \textbf  {\#Indus.\ fam.} = named industrial part families with explicit functional identity (gear, drill, spring, $\ldots  $) versus untyped CAD parts pooled without semantic structure; \textbf  {\#Std codes} = distinct ISO/DIN/EN/ASME/IEC specification codes from which parameter ranges are programmatically sampled; \textbf  {\#Distinct CQ ops} = distinct CadQuery API operations exercised in the released dataset (counts derived from each work's published description; ours from a static analysis of the released family code, see Appendix~\ref {app:ops}); \textbf  {Adv ops} = whether all four advanced operation families (helix, loft/sweep, twist-extrude, parametric involute-gear construction) are exercised; \textbf  {\#Eval} = distinct models reported in the original work's evaluation. BenchCAD additionally introduces a 6-orientation rotation-invariant $64^3$ IoU $\geq 0.99$ verification protocol and ratio-only scale-invariant prompts (\S  \ref {sec:dataset}, \S  \ref {sec:tasks}). {\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 51}$\,$ = supported, part.\, = partial, -- = absent.}}{13}{table.3}\protected@file@percent }
\newlabel{tab:cmp_prior}{{3}{13}{\textbf {BenchCAD versus prior CAD code-generation work.} BenchCAD is designed as a \emph {unified, capability-decomposed evaluation framework} for large-model CAD reasoning, intended to remain useful as the field evolves from current frontier MLLMs (GPT-5.3, Claude Opus 4.7, $\ldots $) toward future CAD agents and generative systems. It is distinct in purpose from the prior CadQuery-VLM lineage (CAD-Recode, cadrille, CADEvolve), which primarily releases training corpora alongside small fine-tuned models (Qwen 1.5B--2B) that saturate near $\sim $92\% IoU on legacy sketch+extrude test splits. \textbf {Columns:} \textbf {Type}: \emph {corpus+model} = training corpus released with a fine-tuned model, \emph {benchmark} = held-out evaluation suite, \emph {dataset} = mixed-purpose CAD design dataset; \textbf {\#Indus.\ fam.} = named industrial part families with explicit functional identity (gear, drill, spring, $\ldots $) versus untyped CAD parts pooled without semantic structure; \textbf {\#Std codes} = distinct ISO/DIN/EN/ASME/IEC specification codes from which parameter ranges are programmatically sampled; \textbf {\#Distinct CQ ops} = distinct CadQuery API operations exercised in the released dataset (counts derived from each work's published description; ours from a static analysis of the released family code, see Appendix~\ref {app:ops}); \textbf {Adv ops} = whether all four advanced operation families (helix, loft/sweep, twist-extrude, parametric involute-gear construction) are exercised; \textbf {\#Eval} = distinct models reported in the original work's evaluation. BenchCAD additionally introduces a 6-orientation rotation-invariant $64^3$ IoU $\geq 0.99$ verification protocol and ratio-only scale-invariant prompts (\S \ref {sec:dataset}, \S \ref {sec:tasks}). \cmark $\,$ = supported, part.\, = partial, -- = absent}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {Standard-anchored families.} 49\% of BenchCAD families (52/106) bind their parameters to ISO/DIN/EN/ASME/IEC specification tables, sampling at values drawn from real engineering ranges rather than arbitrary geometry. The bottom row counts the 54 custom families covering bespoke industrial parts (twisted brackets, lobed knobs, etc.) governed by analogous proportional rules without formal standards.}}{13}{table.4}\protected@file@percent }
\newlabel{tab:standards}{{4}{13}{\textbf {Standard-anchored families.} 49\% of BenchCAD families (52/106) bind their parameters to ISO/DIN/EN/ASME/IEC specification tables, sampling at values drawn from real engineering ranges rather than arbitrary geometry. The bottom row counts the 54 custom families covering bespoke industrial parts (twisted brackets, lobed knobs, etc.) governed by analogous proportional rules without formal standards}{table.4}{}}
