# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEY1=your-openai-api-key-alternate  # optional, for key rotation
OPENAI_MODEL=gpt-5.2

# Zhipu AI (智谱 / GLM) — text + vision via glm-4*/glm-4.5-v/glm-4.6
ZHIPU_API_KEY=your-zhipu-api-key

# Anthropic Claude — claude-opus-4-*/sonnet-4-*/haiku-4-*
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini — gemini-2.5-*/2.0-*/1.5-* (either var works)
GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-gemini-api-key

# xAI Grok — grok-2-vision/grok-3/grok-4
XAI_API_KEY=your-xai-api-key

# DeepSeek — deepseek-chat (V3) + deepseek-reasoner (R1)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Mistral — mistral-*/pixtral-*/magistral-*/codestral-*
MISTRAL_API_KEY=your-mistral-api-key

# Hypergraph Storage
HYPERGRAPH_STORE_PATH=./data/hypergraph.json
