# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEY1=your-openai-api-key-alternate  # optional, for key rotation
OPENAI_MODEL=gpt-5.2

# Zhipu AI (ZAI) — fallback provider for data generation
