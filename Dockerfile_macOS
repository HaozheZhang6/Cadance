# macOS host variant:
# - force linux/amd64 for better CadQuery/Open3D wheel compatibility on Apple Silicon
# - CPU-only because Docker Desktop on macOS cannot expose host GPU into Linux containers
FROM --platform=linux/amd64 python:3.11-slim-bookworm

ARG OPEN3D_BUILD_JOBS=1

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy

RUN apt-get update && apt-get install -y \
    bash curl git git-lfs wget ca-certificates gnupg build-essential \
    cmake ninja-build python3-dev pkg-config \
    libgl1 libosmesa6-dev libglu1-mesa-dev libglib2.0-0 libgomp1 \
    libxi-dev libxrandr-dev libxinerama-dev libxcursor-dev \
    libfontconfig1 libxrender1 libice6 libsm6 \
    && git lfs install --system \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /workspace
COPY . .

# Install project deps first so the Open3D wheel lands in the same uv-managed env.
RUN uv sync --no-dev

# Keep the same headless Open3D build as the Linux/WSL image.
# On Apple Silicon this runs via amd64 emulation, so expect a slower build.
RUN git clone https://github.com/isl-org/Open3D.git /tmp/Open3D \
    && cd /tmp/Open3D \
    && git checkout 8e434558a9b1ecacba7854da7601a07e8bdceb26 \
    && mkdir build && cd build \
    && cmake -G Ninja \
             -DENABLE_HEADLESS_RENDERING=ON -DBUILD_GUI=OFF \
             -DUSE_SYSTEM_GLEW=OFF -DUSE_SYSTEM_GLFW=OFF \
             -DPYTHON_EXECUTABLE=$(python3 -c "import sys; print(sys.executable)") .. \
    && cmake --build . --parallel "${OPEN3D_BUILD_JOBS}" --target install-pip-package \
    && rm -rf /tmp/Open3D

RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

ENV NPM_CONFIG_PREFIX=/npm-global
ENV PATH="/npm-global/bin:$PATH"

RUN npm install -g @anthropic-ai/claude-code

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["claude", "--dangerously-skip-permissions"]
